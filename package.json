{
  "name": "next-gen-polio-vax-tpp-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=24.0.0" },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "test:fixtures": "Rscript tests/scripts/reference-fixture-generator.R",
    "generate:calibration-report": "node --import tsx scripts/generate-calibration-report.ts --write",
    "check:calibration": "node --import tsx scripts/generate-calibration-report.ts --check",
    "check:performance": "node --import tsx scripts/check-performance.ts",
    "check:cache-memory": "node --expose-gc --import tsx scripts/check-cache-memory.ts",
    "check:reference-fixtures": "node scripts/check-reference-fixtures.mjs",
    "build": "node scripts/build.mjs",
    "record:artifact-hash": "node scripts/check-artifact.mjs --write-hash",
    "check:artifact": "node scripts/check-artifact.mjs && node scripts/browser-smoke.mjs",
    "check:release-negative": "node scripts/check-release-negative.mjs",
    "verify": "npm run typecheck && npm test && npm run test:fixtures && npm run check:reference-fixtures && npm run check:calibration && npm run check:performance && npm run check:cache-memory && npm run build && npm run check:artifact && npm run check:release-negative"
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "d3-contour": "^4.0.2",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0"
  },
  "devDependencies": {
    "@types/d3-array": "^3.2.1",
    "@types/d3-contour": "^3.0.6",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.7",
    "@types/node": "^22.15.21",
    "esbuild": "^0.25.6",
    "playwright": "^1.52.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
